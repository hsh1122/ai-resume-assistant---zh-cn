# Backend environment example.
# Copy this file to .env for local development.
# For production, set the same variables through your hosting platform or secret manager.

# Optional: leave empty to use the local mock AI fallback
OPENAI_API_KEY=you-apikey
OPENAI_BASE_URL=https://api.deepseek.com/v1
OPENAI_MODEL=deepseek-chat

# Optional in local development; defaults to a SQLite file in backend/
DATABASE_URL=sqlite:///./resume_assistant.db

# Required in every environment: set a long random secret before starting the backend
JWT_SECRET_KEY=change_me

# Optional unless you need a different algorithm or expiry window
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Required for browser access; comma-separated list.
# Local development example:
# CORS_ALLOWED_ORIGINS=http://127.0.0.1:5173,http://localhost:5173
# Production example:
# CORS_ALLOWED_ORIGINS=https://resume.example.com
CORS_ALLOWED_ORIGINS=http://127.0.0.1:5173,http://localhost:5173
