{
  "name": "ai-resume-assistant-zh-cn",
  "version": "1.0.0",
  "description": "AI Resume Assistant is a small full-stack workspace for tailoring a resume to a target job description. It combines a React dashboard, a FastAPI backend, JWT authentication, SQLite persistence, and an OpenAI-compatible AI layer with a deterministic mock fallback.",
  "main": "index.js",
  "directories": {
    "doc": "docs"
  },
  "scripts": {
    "backend": "cd backend && .venv\\Scripts\\python.exe -m uvicorn app.main:app --reload",
    "frontend": "cd frontend && npm run dev",
    "dev": "concurrently \"npm run backend\" \"npm run frontend\""
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/hsh1122/ai-resume-assistant---zh-cn.git"
  },
